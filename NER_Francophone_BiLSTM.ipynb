   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Reconnaissance d'Entites Nommees (NER) — Francais\n",
    "**Modele BiLSTM entraine sur WikiNER-FR (~120k phrases Wikipedia)**\n",
    "\n",
    "| Element | Detail |\n",
    "|---|---|\n",
    "| Framework | PyTorch |\n",
    "| Architecture | Embedding → BiLSTM (2 couches) → Dropout → Linear |\n",
    "| Corpus | [WikiNER-FR](https://huggingface.co/datasets/Jean-Baptiste/wikiner_fr) |\n",
    "| Classes | `O`, `LOC`, `PER`, `MISC`, `ORG` |"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "!pip install -q datasets"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Imports"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import json\n",
    "import time\n",
    "from collections import Counter\n",
    "from pathlib import Path\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from torch.nn.utils.rnn import pad_sequence\n",
    "from torch.utils.data import DataLoader, Dataset\n",
    "from datasets import load_dataset\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"Device : {DEVICE}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Chargement du corpus WikiNER-FR"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "ds_train = load_dataset(\"Jean-Baptiste/wikiner_fr\", split=\"train\")\n",
    "ds_test = load_dataset(\"Jean-Baptiste/wikiner_fr\", split=\"test\")\n",
    "\n",
    "TAG_NAMES = ds_train.features[\"ner_tags\"].feature.names\n",
    "TAG_TO_ID = {t: i for i, t in enumerate(TAG_NAMES)}\n",
    "ID_TO_TAG = {i: t for t, i in TAG_TO_ID.items()}\n",
    "PAD_TAG_ID = -100\n",
    "\n",
    "print(f\"Train : {len(ds_train)} phrases\")\n",
    "print(f\"Test  : {len(ds_test)} phrases\")\n",
    "print(f\"Tags  : {TAG_NAMES}\")\n",
    "print(f\"\\nExemple :\")\n",
    "print(f\"  Tokens : {ds_train[0]['tokens']}\")\n",
    "print(f\"  Tags   : {[ID_TO_TAG[t] for t in ds_train[0]['ner_tags']]}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Preparation des donnees"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import random\n",
    "\n",
    "random.seed(42)\n",
    "indices = list(range(len(ds_train)))\n",
    "random.shuffle(indices)\n",
    "val_size = int(len(ds_train) * 0.1)\n",
    "\n",
    "val_indices = indices[:val_size]\n",
    "train_indices = indices[val_size:]\n",
    "\n",
    "print(f\"Train : {len(train_indices)} | Val : {len(val_indices)} | Test : {len(ds_test)}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "class Vocabulary:\n",
    "    \"\"\"Vocabulaire mot -> index avec tokens speciaux.\"\"\"\n",
    "\n",
    "    PAD = \"<PAD>\"\n",
    "    UNK = \"<UNK>\"\n",
    "\n",
    "    def __init__(self):\n",
    "        self.word2idx: dict[str, int] = {self.PAD: 0, self.UNK: 1}\n",
    "        self.idx2word: dict[int, str] = {0: self.PAD, 1: self.UNK}\n",
    "\n",
    "    def build(self, sentences: list[list[str]], min_freq: int = 2) -> \"Vocabulary\":\n",
    "        counter: Counter = Counter()\n",
    "        for tokens in sentences:\n",
    "            counter.update(t.lower() for t in tokens)\n",
    "        for word, freq in counter.items():\n",
    "            if freq >= min_freq:\n",
    "                idx = len(self.word2idx)\n",
    "                self.word2idx[word] = idx\n",
    "                self.idx2word[idx] = word\n",
    "        return self\n",
    "\n",
    "    def encode(self, tokens: list[str]) -> list[int]:\n",
    "        return [self.word2idx.get(t.lower(), 1) for t in tokens]\n",
    "\n",
    "    def __len__(self) -> int:\n",
    "        return len(self.word2idx)\n",
    "\n",
    "\n",
    "vocab = Vocabulary().build(\n",
    "    [ds_train[i][\"tokens\"] for i in train_indices], min_freq=2\n",
    ")\n",
    "print(f\"Vocabulaire : {len(vocab)} mots\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "MAX_SEQ_LEN = 128\n",
    "\n",
    "\n",
    "class NERDataset(Dataset):\n",
    "    \"\"\"Dataset NER : chaque element est (token_ids, tag_ids).\"\"\"\n",
    "\n",
    "    def __init__(self, hf_dataset, indices, vocab, max_len=MAX_SEQ_LEN):\n",
    "        self.samples = []\n",
    "        for i in indices:\n",
    "            item = hf_dataset[i]\n",
    "            tokens = item[\"tokens\"][:max_len]\n",
    "            tags = item[\"ner_tags\"][:max_len]\n",
    "            token_ids = torch.tensor(vocab.encode(tokens), dtype=torch.long)\n",
    "            tag_ids = torch.tensor(tags, dtype=torch.long)\n",
    "            self.samples.append((token_ids, tag_ids))\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.samples)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        return self.samples[idx]\n",
    "\n",
    "\n",
    "class NERDatasetFromHF(Dataset):\n",
    "    \"\"\"Dataset NER directement depuis un split HuggingFace.\"\"\"\n",
    "\n",
    "    def __init__(self, hf_dataset, vocab, max_len=MAX_SEQ_LEN):\n",
    "        self.samples = []\n",
    "        for item in hf_dataset:\n",
    "            tokens = item[\"tokens\"][:max_len]\n",
    "            tags = item[\"ner_tags\"][:max_len]\n",
    "            token_ids = torch.tensor(vocab.encode(tokens), dtype=torch.long)\n",
    "            tag_ids = torch.tensor(tags, dtype=torch.long)\n",
    "            self.samples.append((token_ids, tag_ids))\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.samples)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        return self.samples[idx]\n",
    "\n",
    "\n",
    "def collate_fn(batch):\n",
    "    \"\"\"Padding dynamique par batch.\"\"\"\n",
    "    tokens, tags = zip(*batch)\n",
    "    tokens_padded = pad_sequence(tokens, batch_first=True, padding_value=0)\n",
    "    tags_padded = pad_sequence(tags, batch_first=True, padding_value=PAD_TAG_ID)\n",
    "    return tokens_padded, tags_padded\n",
    "\n",
    "\n",
    "train_ds = NERDataset(ds_train, train_indices, vocab)\n",
    "val_ds = NERDataset(ds_train, val_indices, vocab)\n",
    "test_ds = NERDatasetFromHF(ds_test, vocab)\n",
    "\n",
    "BATCH_SIZE = 64\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True, collate_fn=collate_fn)\n",
    "val_loader = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False, collate_fn=collate_fn)\n",
    "test_loader = DataLoader(test_ds, batch_size=BATCH_SIZE, shuffle=False, collate_fn=collate_fn)\n",
    "\n",
    "print(f\"Train : {len(train_ds)} | Val : {len(val_ds)} | Test : {len(test_ds)}\")\n",
    "print(f\"Batches par epoch : {len(train_loader)}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Modele BiLSTM-NER"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "class BiLSTMNER(nn.Module):\n",
    "    \"\"\"Modele BiLSTM pour la reconnaissance d'entites nommees.\n",
    "\n",
    "    Architecture :\n",
    "        Embedding -> Dropout -> BiLSTM (2 couches) -> Dropout -> Linear\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(\n",
    "        self,\n",
    "        vocab_size: int,\n",
    "        embedding_dim: int = 128,\n",
    "        hidden_dim: int = 128,\n",
    "        num_tags: int = len(TAG_NAMES),\n",
    "        dropout: float = 0.3,\n",
    "        padding_idx: int = 0,\n",
    "    ):\n",
    "        super().__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embedding_dim, padding_idx=padding_idx)\n",
    "        self.dropout_emb = nn.Dropout(dropout)\n",
    "        self.lstm = nn.LSTM(\n",
    "            embedding_dim,\n",
    "            hidden_dim,\n",
    "            num_layers=2,\n",
    "            batch_first=True,\n",
    "            bidirectional=True,\n",
    "            dropout=dropout,\n",
    "        )\n",
    "        self.dropout_lstm = nn.Dropout(dropout)\n",
    "        self.classifier = nn.Linear(hidden_dim * 2, num_tags)\n",
    "\n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        emb = self.dropout_emb(self.embedding(x))\n",
    "        lstm_out, _ = self.lstm(emb)\n",
    "        lstm_out = self.dropout_lstm(lstm_out)\n",
    "        return self.classifier(lstm_out)\n",
    "\n",
    "\n",
    "EMBEDDING_DIM = 128\n",
    "HIDDEN_DIM = 128\n",
    "DROPOUT = 0.3\n",
    "\n",
    "model = BiLSTMNER(\n",
    "    vocab_size=len(vocab),\n",
    "    embedding_dim=EMBEDDING_DIM,\n",
    "    hidden_dim=HIDDEN_DIM,\n",
    "    dropout=DROPOUT,\n",
    ").to(DEVICE)\n",
    "\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "print(f\"Parametres : {total_params:,}\")\n",
    "print(model)"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Entrainement"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "def compute_metrics(model, loader, device):\n",
    "    \"\"\"Loss et accuracy masquee (hors padding).\"\"\"\n",
    "    model.eval()\n",
    "    criterion = nn.CrossEntropyLoss(ignore_index=PAD_TAG_ID)\n",
    "    total_loss, correct, total = 0.0, 0, 0\n",
    "    with torch.no_grad():\n",
    "        for tokens, tags in loader:\n",
    "            tokens, tags = tokens.to(device), tags.to(device)\n",
    "            logits = model(tokens)\n",
    "            loss = criterion(logits.view(-1, logits.size(-1)), tags.view(-1))\n",
    "            total_loss += loss.item() * tokens.size(0)\n",
    "            preds = logits.argmax(dim=-1)\n",
    "            mask = tags != PAD_TAG_ID\n",
    "            correct += (preds[mask] == tags[mask]).sum().item()\n",
    "            total += mask.sum().item()\n",
    "    return {\n",
    "        \"loss\": total_loss / len(loader.dataset),\n",
    "        \"accuracy\": correct / total if total > 0 else 0.0,\n",
    "    }"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "LEARNING_RATE = 1e-3\n",
    "MAX_EPOCHS = 15\n",
    "PATIENCE = 3\n",
    "\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=LEARNING_RATE)\n",
    "scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode=\"min\", factor=0.5, patience=1)\n",
    "criterion = nn.CrossEntropyLoss(ignore_index=PAD_TAG_ID)\n",
    "\n",
    "history = {\"train_loss\": [], \"val_loss\": [], \"val_acc\": []}\n",
    "best_val_loss = float(\"inf\")\n",
    "patience_counter = 0\n",
    "\n",
    "for epoch in range(1, MAX_EPOCHS + 1):\n",
    "    model.train()\n",
    "    epoch_loss = 0.0\n",
    "    t0 = time.time()\n",
    "\n",
    "    for tokens, tags in train_loader:\n",
    "        tokens, tags = tokens.to(DEVICE), tags.to(DEVICE)\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(tokens)\n",
    "        loss = criterion(logits.view(-1, logits.size(-1)), tags.view(-1))\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), max_norm=5.0)\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item() * tokens.size(0)\n",
    "\n",
    "    train_loss = epoch_loss / len(train_ds)\n",
    "    val = compute_metrics(model, val_loader, DEVICE)\n",
    "    scheduler.step(val[\"loss\"])\n",
    "    elapsed = time.time() - t0\n",
    "\n",
    "    history[\"train_loss\"].append(train_loss)\n",
    "    history[\"val_loss\"].append(val[\"loss\"])\n",
    "    history[\"val_acc\"].append(val[\"accuracy\"])\n",
    "\n",
    "    print(\n",
    "        f\"Epoch {epoch:02d}/{MAX_EPOCHS} | \"\n",
    "        f\"Train Loss: {train_loss:.4f} | \"\n",
    "        f\"Val Loss: {val['loss']:.4f} | \"\n",
    "        f\"Val Acc: {val['accuracy']:.4f} | \"\n",
    "        f\"{elapsed:.1f}s\"\n",
    "    )\n",
    "\n",
    "    if val[\"loss\"] < best_val_loss:\n",
    "        best_val_loss = val[\"loss\"]\n",
    "        patience_counter = 0\n",
    "        torch.save({\n",
    "            \"model_state\": model.state_dict(),\n",
    "            \"vocab_word2idx\": vocab.word2idx,\n",
    "            \"hyperparams\": {\n",
    "                \"embedding_dim\": EMBEDDING_DIM,\n",
    "                \"hidden_dim\": HIDDEN_DIM,\n",
    "                \"dropout\": DROPOUT,\n",
    "                \"num_tags\": len(TAG_NAMES),\n",
    "                \"vocab_size\": len(vocab),\n",
    "            },\n",
    "        }, \"ner_model.pt\")\n",
    "        print(\"  -> Meilleur modele sauvegarde\")\n",
    "    else:\n",
    "        patience_counter += 1\n",
    "        if patience_counter >= PATIENCE:\n",
    "            print(f\"Early stopping a l'epoch {epoch}\")\n",
    "            break\n",
    "\n",
    "print(\"\\nEntrainement termine.\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Courbes d'entrainement"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(13, 4.5))\n",
    "\n",
    "epochs_range = range(1, len(history[\"train_loss\"]) + 1)\n",
    "\n",
    "ax1.plot(epochs_range, history[\"train_loss\"], \"o-\", label=\"Train\", color=\"#818cf8\")\n",
    "ax1.plot(epochs_range, history[\"val_loss\"], \"o-\", label=\"Validation\", color=\"#34d399\")\n",
    "ax1.set_xlabel(\"Epoch\")\n",
    "ax1.set_ylabel(\"Loss\")\n",
    "ax1.set_title(\"Loss\")\n",
    "ax1.legend()\n",
    "ax1.grid(alpha=0.3)\n",
    "\n",
    "ax2.plot(epochs_range, history[\"val_acc\"], \"o-\", color=\"#fbbf24\")\n",
    "ax2.set_xlabel(\"Epoch\")\n",
    "ax2.set_ylabel(\"Accuracy\")\n",
    "ax2.set_title(\"Validation Accuracy\")\n",
    "ax2.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Evaluation sur le test set"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "checkpoint = torch.load(\"ner_model.pt\", map_location=DEVICE, weights_only=True)\n",
    "model.load_state_dict(checkpoint[\"model_state\"])\n",
    "\n",
    "test_metrics = compute_metrics(model, test_loader, DEVICE)\n",
    "print(f\"Test Loss     : {test_metrics['loss']:.4f}\")\n",
    "print(f\"Test Accuracy : {test_metrics['accuracy']:.4f}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Prediction sur des phrases libres"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "def predict(sentence: str) -> list[dict]:\n",
    "    \"\"\"Predit les tags NER pour une phrase francaise.\"\"\"\n",
    "    tokens = sentence.split()\n",
    "    if not tokens:\n",
    "        return []\n",
    "    token_ids = torch.tensor([vocab.encode(tokens)], dtype=torch.long, device=DEVICE)\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = model(token_ids)\n",
    "    pred_ids = logits.argmax(dim=-1).squeeze(0).tolist()\n",
    "    return [{\"token\": tok, \"tag\": ID_TO_TAG[tid]} for tok, tid in zip(tokens, pred_ids)]\n",
    "\n",
    "\n",
    "def display(predictions: list[dict]):\n",
    "    \"\"\"Affichage colore des entites.\"\"\"\n",
    "    colors = {\"PER\": \"\\033[94m\", \"LOC\": \"\\033[92m\", \"ORG\": \"\\033[93m\", \"MISC\": \"\\033[95m\"}\n",
    "    reset = \"\\033[0m\"\n",
    "    parts = []\n",
    "    for p in predictions:\n",
    "        if p[\"tag\"] != \"O\":\n",
    "            c = colors.get(p[\"tag\"], \"\")\n",
    "            parts.append(f\"{c}[{p['token']}]({p['tag']}){reset}\")\n",
    "        else:\n",
    "            parts.append(p[\"token\"])\n",
    "    print(\" \".join(parts))"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "exemples = [\n",
    "    \"Emmanuel Macron a prononce un discours devant l'Assemblee nationale a Paris\",\n",
    "    \"L'equipe de France a remporte la Coupe du Monde en Russie en 2018\",\n",
    "    \"Google et Microsoft investissent massivement dans l'intelligence artificielle en Europe\",\n",
    "    \"Victor Hugo a ecrit Les Miserables pendant son exil a Guernesey\",\n",
    "    \"La Banque de France a publie son rapport annuel a Lyon\",\n",
    "]\n",
    "\n",
    "for phrase in exemples:\n",
    "    preds = predict(phrase)\n",
    "    display(preds)\n",
    "    print()"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Analyse detaillee par classe"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "from collections import defaultdict\n",
    "\n",
    "model.eval()\n",
    "tag_correct = defaultdict(int)\n",
    "tag_total = defaultdict(int)\n",
    "tag_predicted = defaultdict(int)\n",
    "\n",
    "with torch.no_grad():\n",
    "    for tokens, tags in test_loader:\n",
    "        tokens, tags = tokens.to(DEVICE), tags.to(DEVICE)\n",
    "        logits = model(tokens)\n",
    "        preds = logits.argmax(dim=-1)\n",
    "        mask = tags != PAD_TAG_ID\n",
    "\n",
    "        for tag_id, tag_name in ID_TO_TAG.items():\n",
    "            true_mask = (tags == tag_id) & mask\n",
    "            pred_mask = (preds == tag_id) & mask\n",
    "            tag_total[tag_name] += true_mask.sum().item()\n",
    "            tag_predicted[tag_name] += pred_mask.sum().item()\n",
    "            tag_correct[tag_name] += (true_mask & pred_mask).sum().item()\n",
    "\n",
    "print(f\"{'Tag':<8} {'Precision':>10} {'Recall':>10} {'F1':>10} {'Support':>10}\")\n",
    "print(\"-\" * 50)\n",
    "for tag in TAG_NAMES:\n",
    "    p = tag_correct[tag] / tag_predicted[tag] if tag_predicted[tag] > 0 else 0\n",
    "    r = tag_correct[tag] / tag_total[tag] if tag_total[tag] > 0 else 0\n",
    "    f1 = 2 * p * r / (p + r) if (p + r) > 0 else 0\n",
    "    print(f\"{tag:<8} {p:>10.4f} {r:>10.4f} {f1:>10.4f} {tag_total[tag]:>10}\")"
   ],
   "execution_count": null,
   "outputs": []
  },
